
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model users {
  id    Int @id  @default(autoincrement())
  username String  @unique
  password String
  firstname  String
  lastname  String
  website   website[]
  createdAt  DateTime @default(now())
  updatedAt   DateTime  @updatedAt
}

model website {
  id    Int  @id  @default(autoincrement())
  User_ID   Int
  userID   users   @relation(fields: [User_ID] , references: [id])
  url   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime   @updatedAt
  ticks   websiteTick[]
}

enum websiteStatus {
  up
  down
  unknow
}

model websiteTick   {
  id  Int @id  @default(autoincrement())
  Response_time_ms    Int
  Status      websiteStatus
  region_id    Int
  website_id   Int
  website     website @relation(fields: [website_id], references: [id] ,  onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime  @updatedAt
}
