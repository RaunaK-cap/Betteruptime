{
  "name": "betteruptime",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "cd packages/db && bunx prisma generate && cd ../.. ",
    "db:migrate":  "cd packages/db && bunx prisma migrate deploy && cd ../..",
    "start:backend": "cd apps/api && bun run dev",
    "start:backend:migrate": " bun run db:migrate && bun run start:backend",
    "start:frontend": "cd apps/web2 && bun run start "
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
